{
  "name": "filesystem-searcher-ui",
  "version": "0.2.3",
  "description": "Electron UI for filesystem-searcher",
  "author": "Matthew Muller",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "clean": "rimraf --max-retries=3 dist || exit 0",
    "build": "npm run clean && electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "rimraf": "^6.1.3"
  },
  "build": {
    "appId": "com.filesystemsearcher.app",
    "productName": "Filesystem Searcher",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "icon": "build/icon.png",
    "files": [
      "main.js",
      "index.html",
      "build/icon.png"
    ],
    "extraResources": [
      {
        "from": "../target/release/",
        "to": "bin",
        "filter": [
          "filesystem-searcher.exe"
        ]
      }
    ]
  }
}
